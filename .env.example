# ─── WhoUnfollowed — Environment Variables ────────────────────────────────────
# Copy this file to .env.local and fill in values for local development.
# Never commit .env.local or any file containing real secrets.

# ── Site ──────────────────────────────────────────────────────────────────────
# Public URL of the deployment (used for canonical URLs, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Payments ──────────────────────────────────────────────────────────────────
# Set to "true" to enable real Stripe checkout flows.
# Leave as "false" (or unset) during beta — all users get Pro access automatically.
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# ── Email (optional) ──────────────────────────────────────────────────────────
# Resend API key for sending confirmation emails when users export CSV.
# If not set, the email feature is silently skipped — the app works fine without it.
# Get a key at https://resend.com
RESEND_API_KEY=

# ── Future / Pro tier (not yet active) ───────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/whounfollowed
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# LUCIA_SECRET=a-long-random-string-at-least-32-chars
