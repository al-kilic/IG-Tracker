{
  "name": "@ig-tracker/core",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "lint": "NODE_OPTIONS=--max-old-space-size=4096 eslint src",
    "test": "vitest run",
    "make-fixtures": "tsx test/makeFixtures.ts"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
